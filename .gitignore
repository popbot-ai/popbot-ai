# macOS
.DS_Store
.AppleDouble
.LSOverride
# Finder custom-icon resource fork ("Icon\r"). The old `Icon?` rule used `?`
# (any single char), which also matched the dir "build/icons" (the "s") and
# silently dropped our Linux hicolor icon set from the build. We can't rely on a
# literal trailing CR here because .gitattributes normalizes line endings to LF,
# which would strip it — so match the base name and just re-include our real icon
# dir. (A stray file literally named "Icon" is vanishingly unlikely in this repo.)
Icon
!/build/icons/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Vite / build output
dist/
dist-electron/
out/
.vite/
.turbo/

# Electron-builder output
release/
build/Release/

# Native helper build artifacts
native/*/build/
native/*/.build/
native/*/DerivedData/
*.dSYM/

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.idea/
*.swp
*.swo

# Env / secrets
.env
.env.*
!.env.example

# Test coverage
coverage/
.nyc_output/

# Runtime scratch (PopBot writes per-slot state under here in dev)
tmp/

# Logs
*.log
logs/

# Local-only Claude config
.claude/settings.local.json

# Local-only marketing/demo snapshot — not part of the published tool
example/

# Pre-sanitization annotated screenshot (real ticket data shows through) —
# replaced by images/anatomy.png on a sanitized capture
images/screenshot3.png
