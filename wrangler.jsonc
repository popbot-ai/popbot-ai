{
  // Serves the popbot.app marketing site (site/) as a Cloudflare
  // static-assets Worker. `name` must match the Worker in the dashboard.
  // Connect this repo under the Worker's Build → Git repository, branch
  // main; Workers Builds then runs `wrangler deploy` and publishes site/.
  "name": "popbot-site",
  "compatibility_date": "2026-06-22",
  "assets": {
    "directory": "./site"
  }
}
