# Normalize line endings. Without this, a Windows checkout with
# core.autocrlf=true can rewrite shell scripts / shebang files to CRLF,
# which breaks them on macOS/Linux ("bad interpreter").
* text=auto eol=lf

# Scripts must stay LF on every platform.
*.sh   text eol=lf
*.mjs  text eol=lf

# Binary assets — never touch.
*.png  binary
*.ico  binary
*.icns binary
*.woff2 binary
*.ttf  binary

# Prebuilt shado binaries (incl. the extensionless Linux/macOS ELF/Mach-O).
# Mark binary so `* text=auto eol=lf` can never normalize line endings and
# corrupt the executable.
native/shado/bin/** binary
