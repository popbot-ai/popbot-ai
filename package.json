{
  "name": "popbot",
  "productName": "PopBot",
  "version": "0.0.18",
  "private": true,
  "description": "Battle-tested multi-chat, multi-slot agentic coding tool",
  "main": "./out/main/index.js",
  "author": "Proof of Play, Inc.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node scripts/electron-vite.mjs dev",
    "build": "electron-vite build",
    "start": "node scripts/electron-vite.mjs preview",
    "build:shado": "node scripts/build-shado.mjs",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "package:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "package:win": "npm run build:shado && electron-vite build && electron-builder --win --config electron-builder.yml",
    "package:linux": "electron-vite build && electron-builder --linux --config electron-builder.yml",
    "release": "scripts/release.sh",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf out dist release node_modules/.vite",
    "postinstall": "node scripts/install-app-deps.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.153",
    "@anthropic-ai/sdk": "^0.96.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@openai/codex-sdk": "^0.133.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.0.0",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-virtuoso": "^4.18.6",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.9"
  }
}
